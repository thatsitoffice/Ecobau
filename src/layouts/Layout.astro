---
interface Props {
    title?: string;
}

const { title = "Tectum Ecobau – Webdesign Projekt | Tiny Häuser Landingpage" } = Astro.props;
---

<!doctype html>
<html lang="de">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Deine Freiheit, nachhaltig zu leben. Jedes Tiny Haus ist darauf ausgelegt, deinen Komfort, deine Zeit und deine Ambitionen zu erfüllen." />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    </head>
    <body>
        <slot />
    </body>
</html>

<style is:global>
    @import '../styles/global.css';
</style>

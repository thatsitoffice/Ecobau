---
---

<section class="hero" id="hero">
    <img 
        src="/photorealistic-house-with-wooden-architecture-timber-structure.jpg" 
        alt="Tiny Haus - Webdesign Projekt Tectum Ecobau" 
        class="hero-image" 
        loading="eager"
    />
    <div class="hero-content">
        <h1>
            Wir sind<br>
            <span class="highlight">Bewegung</span>
        </h1>
        <h1 style="margin-top: -12px;">
            Wir sind<br>
            <span class="highlight">Entscheidung</span>
        </h1>
        <p class="hero-subtitle">
            Raum entsteht, wenn Klarheit da ist.<br>
            Dieses Onboarding ist der Startpunkt für Struktur, Fokus und eine gemeinsame Richtung.<br>
            Schritt für Schritt schaffen wir die Grundlage für etwas, das Bestand hat.
        </p>
        <div class="hero-cta">
            <a href="#ziele" class="btn btn-primary">STARTE DIE REISE</a>
            <a href="#workflow" class="btn">ÜBERBLICK ANZEIGEN</a>
        </div>
    </div>
    <div class="scroll-indicator">Scroll nach unten</div>
</section>

<script>
    // Parallax effect for hero image
    window.addEventListener('scroll', () => {
        const scrolled = window.pageYOffset;
        const heroImage = document.querySelector('.hero-image');
        if (heroImage && scrolled < window.innerHeight) {
            heroImage.style.transform = `translateY(${scrolled * 0.3}px)`;
        }
    });
</script>
